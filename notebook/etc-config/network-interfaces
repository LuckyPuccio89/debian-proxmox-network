auto lo
iface lo inet loopback
    up ip addr add 192.168.1.40/32 dev lo || true
    down ip addr del 192.168.1.40/32 dev lo || true

iface nic0 inet manual

auto vmbr0
iface vmbr0 inet static
	address 192.168.1.40/24
	gateway 192.168.1.1
	bridge-ports nic0
	bridge-stp off
	bridge-fd 0

#iface wlan0 inet manual

source /etc/network/interfaces.d/*
